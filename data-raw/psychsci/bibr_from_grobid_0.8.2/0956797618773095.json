  "info": [
    {
      "title": "Reply to Ihmels and Ache (2018): Event-Based Conformity Versus Regression to the Mean",
      "keywords": null,
      "doi": "10.1177/0956797618773095",
      "file_hash": "d49d3c92e99accfa",
      "input_format": "TEI XML",
      "file_name": "data-raw/psychsci/grobid_0.8.2/0956797618773095.xml",
      "bibr_version": "10.0",
      "paper_type": "unknown",
      "paper_type_confidence": 0,
      "oecd_l1": null,
      "oecd_l2": null,
      "oecd_confidence": null
    }
  ],
